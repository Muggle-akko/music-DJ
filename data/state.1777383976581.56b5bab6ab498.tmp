          "sourceCode": 200,
          "tags": [],
          "hostIntro": {
            "enabled": true,
            "voiceCueId": "edd0f67dd8684f0231239fa5f2e2cebc8169236a05f727e9e3c1a3ef5dea74b6",
            "startAtMs": 0,
            "estimatedDurationMs": 30476,
            "displayText": "热血之后，让节奏稍微缓一缓，但情绪不能断。《美しき残酷な世界》，日笠陽子的声音里有一种温柔的坚韧。这首歌是动画第一季的片尾曲，每次听完正片的激烈，再听到这个旋律，就像大战过后，士兵们望着夕阳，心里既有悲伤也有希望。今晚的夜空下，这首歌会给你一个安静的拥抱。",
            "audioUrl": "/api/tts/audio/edd0f67dd8684f0231239fa5f2e2cebc8169236a05f727e9e3c1a3ef5dea74b6.mp3",
