        "hostIntro": {
          "enabled": true,
          "voiceCueId": "3b179a5224c447be7a5fef15f18236d94d4442f765c2cd20d43f9cd2ed70f90d",
          "startAtMs": 0,
          "estimatedDurationMs": 24524,
          "displayText": "夏野Natsuno的《透明な町Lo-fi Acoustic》，一首lo-fi风格的纯音乐。木吉他的声音很温暖，像在安静的夜晚，走在一条没什么人的小街上。这首歌没有歌词，很适合需要专注的时候听，不会分散注意力。",
          "audioUrl": "/api/tts/audio/3b179a5224c447be7a5fef15f18236d94d4442f765c2cd20d43f9cd2ed70f90d.mp3",
          "status": "ready",
