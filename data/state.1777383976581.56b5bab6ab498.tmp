        {
          "id": "26608720",
          "provider": "netease",
          "title": "自由の翼",
          "artist": "Linked Horizon",
          "album": "自由への進撃",
          "url": "/api/music/stream?id=26608720",
          "cover": "https://p4.music.126.net/LaVbjh4z6z5D9b5MftfX1A==/109951163597676980.jpg",
          "duration": 328400,
