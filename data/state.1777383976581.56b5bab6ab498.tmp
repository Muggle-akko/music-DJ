        {
          "id": "26324043",
          "provider": "netease",
          "title": "美しき残酷な世界",
          "artist": "日笠陽子",
          "album": "美しき残酷な世界【通常盤】",
          "url": "/api/music/stream?id=26324043",
          "cover": "https://p3.music.126.net/G8jx8FAQa8QZy3zFwVX-kw==/109951163597274620.jpg",
          "duration": 293706,
